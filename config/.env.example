# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=online_exam_system

# Brevo Email API Keys (Get from https://app.brevo.com)
# Sign up for free account to get these keys
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SMTP_KEY=your_smtp_key_here
BREVO_SMTP_LOGIN=your_smtp_login_here

# Google Gemini API Key (Get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Site URL (change for production)
SITE_URL=http://localhost/online_exam_system

# Email toggle (1=enabled, 0=disabled)
# Set to 0 to disable all email notifications
ENABLE_EMAILS=0

# Site Name
SITE_NAME=Online Examination System

# SMTP Settings (Brevo)
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SENDER_EMAIL=noreply@yourapp.com
BREVO_SENDER_NAME=Your App Name

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash